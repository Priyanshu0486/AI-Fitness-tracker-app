    # API Gateway
    handle /api/* {
        reverse_proxy gateway:8080
    }

    # Keycloak
    handle /realms/* {
        reverse_proxy keycloak:8080
    }
    handle /admin/* {
        reverse_proxy keycloak:8080
    }
    handle /resources/* {
        reverse_proxy keycloak:8080
    }

    # Frontend (default - catch all)
    handle {
        reverse_proxy frontend:80
    }
}
